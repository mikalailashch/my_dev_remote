# Standard Salesforce DX directories
**/.sfdx
**/.sf
**/.localdevserver
**/IlluminatedCloud

# LWC configuration files
**/jsconfig.json
**/.eslintrc.json
**/.prettierrc
**/.prettierignore

# LWC Jest tests
**/__tests__/**

# IDE
.vscode/
.idea/
*.iml

# macOS system files
.DS_Store

# Local environment variables
.env
.env.local

# Node modules
node_modules/

# Logs
*.log
logs/

# Package directories
.sfdx/
.localdevserver/

# Test results
test-results/
coverage/
.nyc_output/

# Build artifacts
**/dist/
**/tmp/

